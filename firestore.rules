rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper to check if user is editing their own document
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    // User profile document rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);

      // Friends subcollection
      match /friends/{friendId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
      
      // Chat Threads messages subcollection
      match /chatThreads/{threadId}/messages/{msgId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // Matches history records rules — includes full move history for Rollmate replay
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();

      // Allow subcollections (e.g. moves) for replay data
      match /{subcollection}/{docId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // Challenges in RTDB (this is Firestore rules, so challenges collection in Firestore is not used, 
    // but we can allow it just in case, or remove it. Let's keep it simple).
    match /challenges/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}
